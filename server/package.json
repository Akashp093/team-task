{
  "name": "team-task-manager-server",
  "version": "1.0.0",
  "description": "Express API for Team Task Manager",
  "main": "src/index.js",
  "scripts": {
    "start": "npx prisma generate && npx prisma db push && node src/index.js",
    "dev": "npx prisma generate && node --watch src/index.js",
